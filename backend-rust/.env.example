# === Server ===
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# === Auth ===
SECRET_KEY=your-secret-key-min-32-chars-here
ENCRYPTION_KEY=your-encryption-key-min-32-chars
ENCRYPTION_SALT=react-chatgpt-salt

# === Database ===
DB_CLIENT=sqlite
SQLITE_DB_PATH=database/ChatData.db
# DATABASE_URL=postgres://user:pass@localhost:5432/chatgpt

# === App URL ===
APP_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:1420

# === Auth Cookie ===
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_MAX_AGE_DAYS=7
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=

# === SMTP (optional) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=
# EMAIL_REPLY_TO=

# === DKIM (optional) ===
# DKIM_DOMAIN=example.com
# DKIM_KEY_SELECTOR=default
# DKIM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# === Stripe (optional) ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
# STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
# STRIPE_TEAM_YEARLY_PRICE_ID=price_...

# === OAuth (optional) ===
# Base URL for OAuth callback URIs (must be the backend's external URL)
# OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# Google
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# GitHub
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Apple
# APPLE_CLIENT_ID=com.example.app
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_KEY_ID=XXXXXXXXXX
# APPLE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----

# === Dev ===
DEV_BYPASS_AUTH=true
LOG_LEVEL=debug
